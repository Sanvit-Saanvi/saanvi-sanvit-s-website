    <body> 
        <h1>Mug Cake</h1>
        <div class = "recipes"> 
            <ul class = "ingredients">
                <h2>Ingredients</h2>
                <li>4 tablespoons flour</li> 
                <li>2 tablespoons milk</li>
                <li>2 tablespoons cocoa Powder</li>
                <li>1/2 tablespoon oil</li>
                <li>1 tablespoon choco chips</li>
                <li>1 pinch baking powder</li>
                <li>2 or 3 tablespoons sugar</li>
            </ul>
            
            <img src="https://coconutsandkettlebells.com/wp-content/uploads/healthy-mug-cake-square-recipe.jpg" alt="Mug Cake"/>
           
            <ol class = "instructions">
                <h2>Instructions</h2>
                <li>Gather all ingredients</li>
                <li>Combine them in a mug</li>
                <li>Place in the microwave for about 1 and a half minute</li>
            </ol>
        </div>

        <h1>Cookies</h1>
        <div class = "recipes">
            <ul class = "ingredients">
                <h2>Ingredients</h2>
                <li>1/2 cup flour</li>
                <li>1/4 teaspoon baking powder</li>
                <li>Pinch of salt</li>
                <li>3 tbsp butter, softened</li>
                <li>1/4 cup sugar</li>
                <li>2 tbsp milk</li>
                <li>1/4 tspvanilla extract</li>
                <li>1/4 cup choco chips</li>
            </ul>
            <img src="https://mojo.generalmills.com/api/public/content/_pLFRXFETcuXWg_Z0MhZPw_gmi_hi_res_jpeg.jpeg?v=693b292b&t=466b54bb264e48b199fc8e83ef1136b4" alt="Cookies"/>
            <ol class = "instructions">
                <h2>Instructions</h2>
                <li>Preheat oven to 180 C/ 350 F while making dough</li>
                <li>In bowl, mix/ cream the butter and sugar until smooth</li>
                <li>Add milk and vanilla, mix well</li>
                <li>Add flour,baking powde, and Salt</li>
                <li>Fold/put in chocolate chips</li>
                <li>Scoop enough portions,slightly flatten</li>
                <li>Bake 10-12 minutes</li>
                <li>Cool 5-10 minutes</li>
            </ol>
        </div>
         
        <h1>Brownies</h1>
        <div class = "recipes">

             <ul class = "ingredients">
                <h2>Ingredients</h2>
                <li>3/4 cupflour</li>
                <li>1 cup sugar</li>
                <li>1/4 tsp salt</li>
                <li>2 tsp baking powder</li>
                <li>1/3 cupcocoa powder</li>
                <li>1/2 cup butter, melted and cooled</li>
                <li>1/2 cup + 2 tbsp plain yogurt</li>
                <li>1 1/2 tspvanilla</li>
                <li>1/2 cupchoco chips</li>
            </ul>

            <img src="https://www.southernliving.com/thmb/V_elnSJcMdL1XQo1x93WBMTFSGM=/1500x0/filters:no_upscale():max_bytes(150000):strip_icc()/best-ever-brownies-batch3057-beauty-03-5e228060ebc943e9bbd95a16a3eda1d8.jpg" alt="Brownies"/>
           
            <ol class = "instructions">
                <h2>Instructions</h2>
                <li>Preheat oven to 180 C/ 350 F</li>
                <li>Melt butter in microwave. Let it cool down while prepearing baking pan</li>
                <li>Lightly butter baking pan. Add parchment paper</li>
                <li>Flour sugar salt and baking powder in a bowl and mix</li>
                <li>In a another bowl,take melted butter,add plain yougurt and add vanila extrat.Whisk untill everything mixed and smooth</li>
                <li>Add another mixture whisk untill batter comes together</li>
                <li>Add chocolate chips</li>
                <li>Pour batter into the prepared pan and spead evenly</li>
                <li>Bake in oven 35-40 mins</li>
                <li>Lige paper from sides and transfer it on a cooling rack</li>
                <li>Use a knife to cut into pieces</li>
            </ol>

        </div>

        <h1>Vanilla Cake</h1>
        <div class = "recipes">
            <ul class = "ingredients">
                <h2>Ingredients</h2>
                <li>3 cup flour</li>
                <li>4 1/2 tspbaking powder</li>
                <li>1/4 tsp baking soda</li>
                <li>1 1/2 tspvanilla extract</li>
                <li>3 tbsp sour cream or plain yougurt</li>
                <li>1/2 cup sugar</li>
                <li>3/4 tsp salt</li>
                <li>1 1/2 cup milk</li>
                <li>4 1/2 tsp vinegar</li>
                <li>3/4 cup butter</li>
            </ul>

            <img src = "https://tse3.mm.bing.net/th/id/OIP.6Mehm4JJySyzrff3uYjs-AHaHa?r=0&cb=thfvnextfalcon3&rs=1&pid=ImgDetMain&o=7&rm=3" alt="Vanila Cake">

            <ol class = "instructions">
                <h2>Instructions</h2>
                <li>Preheat the oven and prepare the cake pans</li>
                <li>Combine dry ingredients</li>
                <li>Mix milk and vinegar</li>
                <li>Cream butter and sugar</li>
                <li>Add dry ingredients</li>
                <li>Divide the batter</li>
                <li>Bake</li>
                <li>Decorate (optional)</li>
            </ol>
        </div>




